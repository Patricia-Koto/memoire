    "# ==========================================================\n",
    "# 22. MATRICES DE CONFUSION\n",
    "# ==========================================================\n",
    "for name, fitted_pipe in fitted_models.items():\n",
    "    y_pred = fitted_pipe.predict(X_test)\n",
    "    cm = confusion_matrix(y_test, y_pred)\n",
    "\n",
    "    print(f\"\\n{name}\")\n",
    "    print(\"Matrice de confusion :\")\n",
