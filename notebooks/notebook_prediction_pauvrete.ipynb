    "\n",
    "# Nombre total de ménages ayant un poids non manquant\n",
    "N = df_model[WEIGHT_VAR].notna().sum()\n",
    "\n",
    "# Somme des poids\n",
    "somme_poids = df_model[WEIGHT_VAR].sum(skipna=True)\n",
